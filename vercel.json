{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "env": {
    "NODE_ENV": "production"
  },
  "public": "dist/client",
  "cleanUrls": true,
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/.*\\..*",
      "dest": "/$0"
    },
    {
      "src": "/(.*)",
      "dest": "/api"
    }
  ]
}






